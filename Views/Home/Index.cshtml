                DEF
            </button>

            <button type="button" class="btn btn-outline-danger"
                    style="--bs-btn-padding-y: .25rem; --bs-btn-padding-x: .5rem; --bs-btn-font-size: .75rem; margin-left:10px;">
                GHI
            </button>
        </div>
        
    </div>-->
    <!-- category Button End-->

    <hr />
    <contaner>
        <div>
            <div class="row" style=" margin-left: 18px; margin-bottom:30px; background-color:rgb(14, 26, 43);">
                @foreach (var item in Model)
                {
                    
                    <div class="col mt-3 mb-3 ">
                        <div class="card" style="width: 18rem; " hight="">
                            <img src="~/images/WhatsApp Image 2025-08-03 at 09.29.52_9a443d3a.jpg" class="card-img-top" alt="..." height="300px">
                            <div class="card-body ">
                                <h5 class="card-title">@item.MovieName</h5>

                                <p class="card-text overflow-auto " style="height:95px;">
                                    @item.MovieDescription
                                </p>


                                <p>
                                    @for(int i=1; i<=10;i++)
                                    {
                                        if(i<=item.Rating)
                                        {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-star-fill" style="color:#FF8000;margin-bottom:5px;" viewBox="0 0 16 16">
                                            <path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z" />
                                            </svg>
                                        }
                                        else
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-star" style="color:#FF8000;margin-bottom:5px;" viewBox="0 0 16 16">
                                                <path d="M2.866 14.85c-.078.444.36.791.746.593l4.39-2.256 4.389 2.256c.386.198.824-.149.746-.592l-.83-4.73 3.522-3.356c.33-.314.16-.888-.282-.95l-4.898-.696L8.465.792a.513.513 0 0 0-.927 0L5.354 5.12l-4.898.696c-.441.062-.612.636-.283.95l3.523 3.356-.83 4.73zm4.905-2.767-3.686 1.894.694-3.957a.56.56 0 0 0-.163-.505L1.71 6.745l4.052-.576a.53.53 0 0 0 .393-.288L8 2.223l1.847 3.658a.53.53 0 0 0 .393.288l4.052.575-2.906 2.77a.56.56 0 0 0-.163.506l.694 3.957-3.686-1.894a.5.5 0 0 0-.461 0z" />
                                            </svg>
                                        }
                                    }
                                    
                                    @* @item.Rating *@


                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-tags-fill" style="color:#FF8000;margin-bottom:5px;margin-left:100px;" viewBox="0 0 16 16">
                                        <path d="M2 2a1 1 0 0 1 1-1h4.586a1 1 0 0 1 .707.293l7 7a1 1 0 0 1 0 1.414l-4.586 4.586a1 1 0 0 1-1.414 0l-7-7A1 1 0 0 1 2 6.586zm3.5 4a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3" />
                                        <path d="M1.293 7.793A1 1 0 0 1 1 7.086V2a1 1 0 0 0-1 1v4.586a1 1 0 0 0 .293.707l7 7a1 1 0 0 0 1.414 0l.043-.043z" />
                                    </svg>
                                    @item.MovieCategory
                                </p>
                            </div>
                        </div>
                    </div>


                }
            </div>
        </div>
    </contaner>
</div>