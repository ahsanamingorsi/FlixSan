@model IEnumerable<MovieDetails>

<div style="background-color:rgb(14, 26, 43); color:white;">
    <!-- Image logo start-->
    <div class="row">
        <div class="col-4"></div>
        <div class="col-4 d-flex justify-content-center " >
            <img src="~/images/ae440a5e-69e5-4c9a-867a-a4d396f9c59c-removebg-preview.png" height="110px" width="300px">
            <!-- <h1>FlixSan</h1>-->
           
            </div>
        <div class="col-4"></div>
    </div>
    <!-- Image logo End-->

    <!-- Tagline start-->
    <div class="row" style="margin-top:10px;">
        <div class="col-4"></div>
        <div class="col-4 d-flex justify-content-center ">
            
            <h5>Your World of Movies, Curated by FlixSan</h5>

        </div>       
        <div class="col-4"></div>
    </div> 
    <!-- Tagline End-->
    
    <!-- Search Bar start-->
    <div class="row" style="margin-top:10px; color:white;" >
        <div class="col-4"></div>

        <form class="col-4 d-flex justify-content-center " method="post" asp-controller="Home" asp-action="Index">
        
            <div class="col-3">
            <select id="inputState" class="form-select " name="searchcategory"">
                <option selected>Category</option>
                <option name="searchcategory">Adventure</option>
                <option name="searchcategory">Action</option>
                <option name="searchcategory">Thriller</option>
                <option name="searchcategory">Horrror</option>
                <option name="searchcategory">Comedy</option>
                <option name="searchcategory">Musical</option>
                <option name="searchcategory">Romance</option>
                <option name="searchcategory">Drama</option>
                <option name="searchcategory">Fantasy</option>

            </select>
            </div>
           
                <input class="form-control me-2 " type="search" placeholder="Search Movies" aria-label="Search" name="searchquery"  />
                <button class="btn btn-primary" type="submit">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
                    </svg>
                </button>
            <button class="btn btn-danger " style="margin-left:5px;" type="submit" asp-controller="Home" asp-action="Reset">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-clockwise" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z" />
                    <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466" />
                </svg>
            </button>
            

            
        </form>
        <div class="col-4"></div>
    </div>
    <!-- Search Bar End-->
    
    <!-- category text start-->
    <form method="post" asp-controller="Home" asp-action="Index" >
    <div class="row" >
        <div class="col-4"></div>
        <div class="col-4 flex justify-content-center " >

            
               
                

        </div>
        <div class="col-4"></div>
        </div>
    </form>
    <!-- category text End-->
    
    <!-- category Button start-->
    <!-- <div class="row" style="margin-top:10px;">
        
        <div class="col-12 d-flex justify-content-center ">

            <button type="button" class="btn btn-outline-danger"
                    style="--bs-btn-padding-y: .25rem; --bs-btn-padding-x: .5rem; --bs-btn-font-size: .75rem; ">
                AbC
            </button>
            
            <button type="button" class="btn btn-outline-danger"
                    style="--bs-btn-padding-y: .25rem; --bs-btn-padding-x: .5rem; --bs-btn-font-size: .75rem; margin-left:10px;">
