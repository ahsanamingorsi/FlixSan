@model IEnumerable<MovieDetails>

    <div class="col-12 d-flex justify-content-center">
        <h1>Admin Panel</h1>
    </div>
    <div class="col-12 d-flex justify-content-center">
    <a class="btn btn-outline-success" asp-controller="Home" asp-action="AddMovie">Add Movie</a>
</div>
    <hr>
<div class="col-12 d-flex justify-content-center">
    <h3>Adventure</h3>
</div>
<table class="table table-hover container">
